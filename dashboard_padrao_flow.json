  {
    "id": "n888888888888888",
    "type": "function",
    "z": "f1a2b3c4d5e6f001",
    "name": "incrementa brilho e envia cmd",
    "func": "let brilhoAtual = Number(flow.get(\"lampadaBrilho\"));\nif (!Number.isFinite(brilhoAtual)) {\n    brilhoAtual = 0;\n}\n\nconst novoBrilho = Math.min(100, brilhoAtual + 10);\nflow.set(\"lampadaBrilho\", novoBrilho);\nflow.set(\"lampadaLigada\", true);\n\nconst mqttMsg = {\n    topic: \"casa/sala/lampada/cmd\",\n    payload: { acao: \"ligar\", brilho: novoBrilho }\n};\n\nconst gaugeMsg = { payload: novoBrilho };\nconst statusMsg = { payload: `Ligada (${novoBrilho}%)` };\n\nreturn [mqttMsg, gaugeMsg, statusMsg];",
