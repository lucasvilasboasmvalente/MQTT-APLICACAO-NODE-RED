  {
    "id": "n333333333333333",
    "type": "function",
    "z": "f1a2b3c4d5e6f001",
    "name": "atualiza estado painel",
    "func": "const ligada = msg.payload && msg.payload.ligada === true;\nconst brilhoEntrada = Number(msg.payload && msg.payload.brilho);\nconst brilho = Number.isFinite(brilhoEntrada)\n    ? Math.max(0, Math.min(100, Math.round(brilhoEntrada)))\n    : 0;\n\nflow.set(\"lampadaBrilho\", brilho);\nflow.set(\"lampadaLigada\", ligada);\n\nconst msgBrilho = { payload: brilho };\nconst msgStatus = { payload: ligada ? `Ligada (${brilho}%)` : `Desligada (${brilho}%)` };\n\nreturn [msgBrilho, msgStatus];",
